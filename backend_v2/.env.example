# ============================================================
# Copia questo file in .env e compila i valori reali
# Il file .env NON deve mai essere committato in git
# ============================================================

# --- Server ---
PORT=3005
BACKEND_URL=http://localhost:3005

# Origini permesse per CORS (separare con virgola)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5173

# --- Database SQLite ---
DB_PATH=C:/path/to/inventario.db

# --- Password admin al primo avvio (viene hashata e salvata nel DB) ---
# Dopo il primo avvio puoi rimuoverla
ADMIN_PASSWORD_DEFAULT=cambia_questa_password

# --- JWT Auth (OBBLIGATORIO, min 32 caratteri) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# --- PDF / Puppeteer ---
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# --- Credenziali Amazon LWA ---
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=
LWA_REFRESH_TOKEN=

# --- Chiavi AWS (firma SP-API) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# --- Seller ID Amazon ---
SELLER_ID=

# --- SMTP notifiche email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Nexus Alerts <noreply@example.com>
ALERT_DIGEST_TO=
ALERT_DIGEST_CRON=0 9 * * *

# --- Backup DB ---
# BACKUP_CRON: ogni 4 ore 10-22 (PC spento di notte). Modifica se il server gira 24/7.
# BACKUP_STARTUP_MAX_AGE_HOURS: se l'ultimo backup è più vecchio di N ore, ne fa uno all'avvio
BACKUP_DIR=C:/path/to/backups
# Directory secondaria su disco diverso (opzionale ma consigliato)
BACKUP_DIR_SECONDARY=
BACKUP_MAX_KEEP=7
BACKUP_CRON=0 10,14,18,22 * * *
BACKUP_STARTUP_MAX_AGE_HOURS=12
