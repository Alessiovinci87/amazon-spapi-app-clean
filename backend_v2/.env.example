# ============================================================
# Copia questo file in .env e compila i valori reali
# Il file .env NON deve mai essere committato in git
# ============================================================

# Porta backend
PORT=3005

# Percorso assoluto del database SQLite
DB_PATH=D:/inventario_database/inventario.db

# Percorso eseguibile Chrome/Chromium per generazione PDF
PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# URL base del backend (usato nei template PDF per i loghi)
BACKEND_URL=http://localhost:3005

# Password admin al primo avvio (viene hashata e salvata nel DB)
# Dopo il primo avvio puoi rimuovere questa variabile
ADMIN_PASSWORD_DEFAULT=cambia_questa_password

# --- Credenziali Amazon LWA ---
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=
LWA_REFRESH_TOKEN=

# --- Chiavi AWS (firma SP-API) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# --- Seller ID Amazon ---
SELLER_ID=
